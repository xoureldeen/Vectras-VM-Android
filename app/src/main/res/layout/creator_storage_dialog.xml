<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:animateLayoutChanges="true"
    android:orientation="vertical">

    <com.google.android.material.bottomsheet.BottomSheetDragHandleView
        android:id="@+id/drag_handle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <androidx.core.widget.NestedScrollView
        android:id="@+id/nsv"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scrollbars="vertical"
        android:fadeScrollbars="true"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="48dp">

        <LinearLayout
            android:id="@+id/ln_all_options"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:paddingHorizontal="16dp"
            android:paddingBottom="16dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_title"
                style="@style/MaterialAlertDialog.Material3Expressive.Title.Text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:paddingBottom="16dp"
                android:text="@string/storage" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/driveField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:hint="@string/hard_drive_0"
                android:theme="@style/AppTheme.TextInput"
                app:endIconContentDescription="@string/options"
                app:endIconDrawable="@drawable/add_24px"
                app:endIconMode="custom"
                app:startIconDrawable="@drawable/hard_drive_24px">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/drive"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:editable="false"
                    android:focusable="false"
                    android:inputType="text"
                    android:selectAllOnFocus="true"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_hd1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:hint="@string/hard_drive_1"
                android:theme="@style/AppTheme.TextInput"
                app:endIconContentDescription="@string/options"
                app:endIconDrawable="@drawable/add_24px"
                app:endIconMode="custom"
                app:startIconDrawable="@drawable/hard_drive_24px">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tie_hd1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:editable="false"
                    android:focusable="false"
                    android:inputType="text"
                    android:selectAllOnFocus="true"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="10dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/cdromField"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:hint="@string/optical_drive_0"
                app:endIconContentDescription="@string/options"
                app:endIconDrawable="@drawable/add_24px"
                app:endIconMode="custom"
                android:theme="@style/AppTheme.TextInput"
                app:startIconDrawable="@drawable/album_24px">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/cdrom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:editable="false"
                    android:focusable="false"
                    android:inputType="text"
                    android:selectAllOnFocus="true"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/til_cdrom_1"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:hint="@string/optical_drive_1"
                app:endIconContentDescription="@string/options"
                app:endIconDrawable="@drawable/add_24px"
                app:endIconMode="custom"
                android:theme="@style/AppTheme.TextInput"
                app:startIconDrawable="@drawable/album_24px">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/tie_cdrom_1"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:editable="false"
                    android:focusable="false"
                    android:inputType="text"
                    android:selectAllOnFocus="true"
                    android:singleLine="true" />
            </com.google.android.material.textfield.TextInputLayout>

            <LinearLayout
                android:id="@+id/ln_floppy_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <com.google.android.material.divider.MaterialDivider
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:layout_marginBottom="10dp"/>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_fda"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:hint="@string/floppy_drive_a"
                    android:theme="@style/AppTheme.TextInput"
                    app:endIconDrawable="@drawable/close_24px"
                    app:startIconDrawable="@drawable/save_24px">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tie_fda"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:editable="false"
                        android:focusable="false"
                        android:inputType="text"
                        android:selectAllOnFocus="true"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/til_fdb"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:clickable="true"
                    android:focusable="true"
                    android:hint="@string/floppy_drive_b"
                    android:theme="@style/AppTheme.TextInput"
                    app:endIconDrawable="@drawable/close_24px"
                    app:startIconDrawable="@drawable/save_24px">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/tie_fdb"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:clickable="true"
                        android:editable="false"
                        android:focusable="false"
                        android:inputType="text"
                        android:selectAllOnFocus="true"
                        android:singleLine="true" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <com.google.android.material.divider.MaterialDivider
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="16dp"/>

            <com.vectras.vm.view.SwitchView
                android:id="@+id/sv_shared_folder"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:title="@string/shared_folder"
                app:subtitle="SharedFolder/"
                android:background="@drawable/object_shape_single_high"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>